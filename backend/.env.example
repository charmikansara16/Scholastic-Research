# ScholarAI Backend Configuration Template
# Copy this to '.env' and fill in your details.

# AI Engine API Keys
# Provide at least one key to enable AI-powered matching, otherwise falls back to deterministic match.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Database setup
DATABASE_URL=sqlite:///./scholarships.db

# Dev / Production Configs
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENVIRONMENT=development
RATE_LIMIT_PER_MINUTE=15
